# ─── Database ─────────────────────────────────────────
DATABASE_URL=postgres://hookline:hookline_dev@localhost:5432/hookline
POSTGRES_PASSWORD=hookline_dev

# ─── LLM (pick one) ───────────────────────────────────
LLM_PROVIDER=anthropic
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# ─── Reddit ───────────────────────────────────────────
# Create app at https://www.reddit.com/prefs/apps (type: script)
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=

# ─── Twitter / X ──────────────────────────────────────
# Bearer token from https://developer.twitter.com (Basic tier minimum for search)
X_BEARER_TOKEN=

# ─── Telegram (notifications) ─────────────────────────
# Create a bot via @BotFather, get chat_id from @userinfobot
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ─── Runtime ──────────────────────────────────────────
INSTANCE_ID=hookline-1
HEALTH_PORT=8080
HEARTBEAT_MS=15000
DB_POOL_MAX=10
