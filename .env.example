# ─── Database ─────────────────────────────────────────
DATABASE_URL=postgres://hookline:hookline_dev@localhost:5432/hookline
POSTGRES_PASSWORD=hookline_dev

# ─── LLM Provider ─────────────────────────────────────
# Pick ONE provider. OpenRouter is recommended (one key, all models).
#
# Provider precedence (auto-detected if LLM_PROVIDER unset):
#   OPENROUTER_API_KEY > ANTHROPIC_API_KEY > OPENAI_API_KEY
# Force a specific one with LLM_PROVIDER=openrouter|anthropic|openai
LLM_PROVIDER=openrouter

# OpenRouter — get key at https://openrouter.ai/keys
# Browse model slugs at https://openrouter.ai/models
OPENROUTER_API_KEY=sk-or-v1-xxxxxxxxxxxx

# Optional OpenRouter analytics headers (visible in your dashboard)
OPENROUTER_REFERER=https://github.com/AdityaRuh/openclaw-template
OPENROUTER_APP_NAME=Hookline Lead Gen Agent

# Single model used for both scoring and drafting (override per-role below)
MODEL=anthropic/claude-sonnet-4

# Optional per-role overrides — scoring should be cheap, drafting strong
MODEL_SCORER=anthropic/claude-haiku-4.5
MODEL_DRAFTER=anthropic/claude-sonnet-4

# ─── Direct provider keys (alternative to OpenRouter) ─
# ANTHROPIC_API_KEY=
# OPENAI_API_KEY=

# ─── Reddit ───────────────────────────────────────────
# Create app at https://www.reddit.com/prefs/apps (type: script)
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=

# ─── Twitter / X ──────────────────────────────────────
# Bearer token from https://developer.twitter.com (Basic tier minimum)
X_BEARER_TOKEN=

# ─── Telegram (notifications) ─────────────────────────
# Create a bot via @BotFather, get chat_id from @userinfobot
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ─── Runtime ──────────────────────────────────────────
INSTANCE_ID=hookline-1
HEALTH_PORT=8080
HEARTBEAT_MS=15000
DB_POOL_MAX=10
